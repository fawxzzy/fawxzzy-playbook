{
  "name": "playbook-monorepo",
  "version": "0.1.1",
  "private": true,
  "packageManager": "pnpm@10.23.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "preinstall": "node scripts/assert-install-env.mjs",
    "build": "pnpm run sync:templates && pnpm -r build",
    "lint": "eslint \"{packages,tools,scripts,templates}/**/*.{ts,tsx,js,jsx}\" --max-warnings=0",
    "check:tests": "node scripts/check-tests.mjs",
    "smoke": "pnpm -r build && node scripts/smoke-test.mjs",
    "smoke:ci": "pnpm -r build && node scripts/smoke-test.mjs",
    "pack:smoke": "node scripts/pack-smoke.mjs",
    "test": "node scripts/run-tests.mjs",
    "sync:templates": "node scripts/sync-templates.mjs",
    "verify:repo": "pnpm -r build && pnpm -r test",
    "verify": "pnpm lint && pnpm check:tests && pnpm test && pnpm smoke:ci",
    "playbook": "node scripts/run-playbook.mjs",
    "playbook:help": "node scripts/run-playbook.mjs --help",
    "playbook:diagram": "pnpm -r build && node packages/cli/dist/main.js diagram --repo . --out docs/ARCHITECTURE_DIAGRAMS.md",
    "prepare": "node scripts/prepare.mjs",
    "pack:check": "node scripts/check-pack.mjs",
    "pack:cli": "pnpm -C packages/cli pack --out ../../packages/cli/fawxzzy-playbook-%v.tgz",
    "docs:merge": "node scripts/docs-merge.mjs",
    "test:cli": "node scripts/cli-smoke.mjs",
    "test:update-snapshots": "UPDATE_CONTRACT_SNAPSHOTS=1 pnpm -C packages/cli test -- cliContracts.test.ts",
    "agents:update": "pnpm docs:update",
    "agents:check": "pnpm docs:check",
    "docs:update": "pnpm -r build && node scripts/update-managed-docs.mjs",
    "docs:check": "pnpm -r build && node scripts/update-managed-docs.mjs --check",
    "test:security": "pnpm -r build && node --test test/contracts/security/**/*.test.mjs test/security/**/*.test.mjs",
    "validate:roadmap": "node scripts/validate-roadmap-contract.mjs",
    "pr:sync-metadata": "node scripts/sync-pr-metadata.mjs",
    "pilot": "node scripts/run-pilot.mjs",
    "test:targeted": "pnpm test -- ask && pnpm test -- ai-contract && pnpm test -- schema && pnpm test -- doctor"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ],
    "supportedArchitectures": {
      "os": [
        "linux",
        "darwin",
        "win32"
      ],
      "cpu": [
        "x64"
      ],
      "libc": [
        "glibc"
      ]
    }
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.30.1",
    "@typescript-eslint/parser": "^8.30.1",
    "@types/node": "^22.13.10",
    "eslint": "^9.24.0",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "*"
  }
}
