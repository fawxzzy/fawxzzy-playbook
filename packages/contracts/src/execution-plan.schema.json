{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://playbook.dev/schemas/execution-plan.schema.json",
  "title": "Execution Plan Artifact",
  "description": "Deterministic proposal-only task execution plan selected from routing evidence and optional learning artifacts.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "kind",
    "generatedAt",
    "proposalOnly",
    "task_family",
    "route_id",
    "rule_packs",
    "required_validations",
    "optional_validations",
    "parallel_lanes",
    "mutation_allowed",
    "missing_prerequisites",
    "sourceArtifacts",
    "learning_state_available",
    "route_confidence",
    "expected_surfaces",
    "likely_conflict_surfaces",
    "dependency_level",
    "recommended_pr_size",
    "worker_ready",
    "open_questions",
    "warnings"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "1.0"
    },
    "kind": {
      "type": "string",
      "const": "execution-plan"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "proposalOnly": {
      "type": "boolean",
      "const": true
    },
    "task_family": {
      "type": "string",
      "minLength": 1
    },
    "route_id": {
      "type": "string",
      "minLength": 1
    },
    "rule_packs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "required_validations": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "optional_validations": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "parallel_lanes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "mutation_allowed": {
      "type": "boolean"
    },
    "missing_prerequisites": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "sourceArtifacts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "taskExecutionProfile",
        "learningState"
      ],
      "properties": {
        "taskExecutionProfile": {
          "$ref": "#/$defs/sourceArtifact"
        },
        "learningState": {
          "$ref": "#/$defs/sourceArtifact"
        }
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "learning_state_available": {
      "type": "boolean"
    },
    "route_confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "expected_surfaces": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "likely_conflict_surfaces": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "dependency_level": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "recommended_pr_size": {
      "type": "string",
      "enum": [
        "small",
        "medium",
        "large"
      ]
    },
    "worker_ready": {
      "type": "boolean"
    },
    "open_questions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "story_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "story_reference",
        "id",
        "title",
        "status",
        "artifact_path",
        "suggested_route",
        "execution_lane"
      ],
      "properties": {
        "story_reference": {
          "type": "string",
          "minLength": 1
        },
        "id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "proposed",
            "ready",
            "in_progress",
            "blocked",
            "done",
            "archived"
          ]
        },
        "artifact_path": {
          "type": "string",
          "const": ".playbook/stories.json"
        },
        "suggested_route": {
          "type": [
            "string",
            "null"
          ]
        },
        "execution_lane": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    }
  },
  "$defs": {
    "sourceArtifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "available",
        "artifactPath"
      ],
      "properties": {
        "available": {
          "type": "boolean"
        },
        "artifactPath": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
