{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fawxzzy.dev/schemas/playbook.research.integration-map.v1.json",
  "title": "Playbook Research Integration Map v1",
  "type": "object",
  "required": [
    "schemaVersion",
    "entries"
  ],
  "properties": {
    "schemaVersion": {
      "const": "playbook.research.integration-map.v1"
    },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "project",
          "adoption",
          "architectureFit",
          "improvesOrReplaces",
          "minimalImplementation"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
          },
          "project": {
            "enum": [
              "Playbook",
              "Fitness",
              "Lifeline"
            ]
          },
          "adoption": {
            "type": "string",
            "minLength": 1
          },
          "architectureFit": {
            "type": "string",
            "minLength": 1
          },
          "improvesOrReplaces": {
            "type": "string",
            "minLength": 1
          },
          "minimalImplementation": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
