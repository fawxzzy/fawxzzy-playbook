{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://playbook.dev/schemas/cross-repo-candidates.schema.json",
  "title": "Cross-Repository Pattern Candidates Artifact",
  "description": "Deterministic additive contract for normalized candidate family aggregates across repositories.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "kind",
    "generatedAt",
    "repositories",
    "families"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "1.0"
    },
    "kind": {
      "type": "string",
      "const": "cross-repo-candidates"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "repositories": {
      "type": "array",
      "description": "Deterministically ordered repository identifiers included in this aggregate run.",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "families": {
      "type": "array",
      "description": "Additive family aggregates emitted in deterministic pattern_family order.",
      "items": {
        "$ref": "#/$defs/crossRepoCandidateFamily"
      }
    }
  },
  "$defs": {
    "crossRepoCandidateFamily": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "pattern_family",
        "repo_count",
        "candidate_count",
        "mean_confidence",
        "repos",
        "first_seen",
        "last_seen"
      ],
      "properties": {
        "pattern_family": {
          "type": "string",
          "minLength": 1
        },
        "repo_count": {
          "type": "integer",
          "minimum": 0,
          "maximum": 1000000
        },
        "candidate_count": {
          "type": "integer",
          "minimum": 0,
          "maximum": 1000000000
        },
        "mean_confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "repos": {
          "type": "array",
          "description": "Deterministically ordered repository identifiers contributing to this family aggregate.",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "first_seen": {
          "type": "string",
          "format": "date-time"
        },
        "last_seen": {
          "type": "string",
          "format": "date-time"
        }
      }
    }
  }
}
