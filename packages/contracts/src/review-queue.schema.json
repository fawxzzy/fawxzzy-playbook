{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://playbook.dev/schemas/review-queue.schema.json",
  "title": "Review Queue",
  "description": "Read-only retrieval review queue artifact for reaffirm/revise/supersede review targets.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "kind",
    "proposalOnly",
    "authority",
    "generatedAt",
    "entries"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "1.0"
    },
    "kind": {
      "type": "string",
      "const": "playbook-review-queue"
    },
    "proposalOnly": {
      "type": "boolean",
      "const": true
    },
    "authority": {
      "type": "string",
      "const": "read-only"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "queueEntryId",
          "targetKind",
          "cadenceKind",
          "sourceSurface",
          "reasonCode",
          "evidenceRefs",
          "triggerType",
          "triggerSource",
          "triggerReasonCode",
          "triggerEvidenceRefs",
          "triggerStrength",
          "recommendedAction",
          "reviewPriority",
          "generatedAt"
        ],
        "properties": {
          "queueEntryId": {
            "type": "string",
            "minLength": 1
          },
          "targetKind": {
            "type": "string",
            "enum": [
              "knowledge",
              "doc"
            ]
          },
          "cadenceKind": {
            "type": "string",
            "enum": [
              "pattern",
              "rule",
              "doc",
              "knowledge"
            ]
          },
          "targetId": {
            "type": "string",
            "minLength": 1
          },
          "path": {
            "type": "string",
            "minLength": 1
          },
          "sourceSurface": {
            "type": "string",
            "minLength": 1
          },
          "reasonCode": {
            "type": "string",
            "minLength": 1
          },
          "evidenceRefs": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "triggerType": {
            "type": "string",
            "enum": [
              "cadence",
              "evidence",
              "cadence+evidence"
            ]
          },
          "triggerSource": {
            "type": "string",
            "minLength": 1
          },
          "triggerReasonCode": {
            "type": "string",
            "minLength": 1
          },
          "triggerEvidenceRefs": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "triggerStrength": {
            "type": "integer",
            "minimum": 0,
            "maximum": 100
          },
          "recommendedAction": {
            "type": "string",
            "enum": [
              "reaffirm",
              "revise",
              "supersede"
            ]
          },
          "reviewPriority": {
            "type": "string",
            "enum": [
              "high",
              "medium",
              "low"
            ]
          },
          "nextReviewAt": {
            "type": "string",
            "format": "date-time"
          },
          "deferredUntil": {
            "type": "string",
            "format": "date-time"
          },
          "overdue": {
            "type": "boolean"
          },
          "generatedAt": {
            "type": "string",
            "format": "date-time"
          }
        },
        "allOf": [
          {
            "anyOf": [
              {
                "required": [
                  "targetId"
                ]
              },
              {
                "required": [
                  "path"
                ]
              }
            ]
          }
        ]
      }
    }
  }
}
