{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://playbook.dev/schemas/interop-followups.schema.json",
  "title": "Playbook Interop Followups Artifact",
  "description": "Deterministic proposal-only followups compiled from interop updated truth so next steps stay explicit and auditable.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "kind",
    "command",
    "reviewOnly",
    "authority",
    "sourceArtifact",
    "followups"
  ],
  "properties": {
    "schemaVersion": { "const": "1.0" },
    "kind": { "const": "interop-followups-artifact" },
    "command": { "const": "interop followups" },
    "reviewOnly": { "const": true },
    "authority": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mutation", "promotion"],
      "properties": {
        "mutation": { "const": "read-only" },
        "promotion": { "const": "review-required" }
      }
    },
    "sourceArtifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "contractSourceHash", "contractSourceRef", "contractSourcePath"],
      "properties": {
        "path": { "const": ".playbook/interop-updated-truth.json" },
        "contractSourceHash": { "type": "string", "minLength": 1 },
        "contractSourceRef": { "type": "string", "minLength": 1 },
        "contractSourcePath": { "type": "string", "minLength": 1 }
      }
    },
    "followups": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "followupId",
          "source",
          "action",
          "targetSurface",
          "followupType",
          "provenanceRefs",
          "nextActionText",
          "confidence"
        ],
        "properties": {
          "followupId": { "type": "string", "minLength": 1 },
          "source": {
            "type": "object",
            "additionalProperties": false,
            "required": ["receiptId", "requestId"],
            "properties": {
              "receiptId": { "type": "string", "minLength": 1 },
              "requestId": { "type": "string", "minLength": 1 }
            }
          },
          "action": {
            "enum": [
              "queue-memory-candidate",
              "queue-next-plan-hint",
              "queue-review-cue",
              "queue-docs-story-followup"
            ]
          },
          "targetSurface": {
            "enum": [
              ".playbook/memory/candidates.json",
              ".playbook/plan.json",
              ".playbook/review-queue.json",
              ".playbook/stories.json"
            ]
          },
          "followupType": {
            "enum": ["memory-candidate", "next-plan-hint", "review-cue", "docs-story-followup"]
          },
          "provenanceRefs": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "nextActionText": { "type": "string", "minLength": 1 },
          "confidence": {
            "type": "object",
            "additionalProperties": false,
            "required": ["score", "rationale"],
            "properties": {
              "score": { "type": "number", "minimum": 0, "maximum": 1 },
              "rationale": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    }
  }
}
