{
  "version": 1,
  "subsystems": [
    {
      "name": "bootstrap_contract_surface",
      "purpose": "Machine-readable interface for humans and agents",
      "commands": [
        "context",
        "ai-context",
        "ai-contract",
        "contracts"
      ],
      "artifacts": [
        ".playbook/ai-contract.json"
      ],
      "upstream": [
        "governance_kernel"
      ],
      "downstream": [
        "observation_engine",
        "knowledge_lifecycle"
      ]
    },
    {
      "name": "observation_engine",
      "purpose": "Deterministic repository understanding",
      "commands": [
        "index",
        "graph",
        "query",
        "deps",
        "ask",
        "explain",
        "analyze-pr",
        "doctor"
      ],
      "artifacts": [
        ".playbook/repo-index.json",
        ".playbook/repo-graph.json"
      ]
    },
    {
      "name": "governance_kernel",
      "purpose": "Rules, CI enforcement, fail-closed guarantees",
      "commands": [
        "verify",
        "docs",
        "audit",
        "rules"
      ],
      "artifacts": []
    },
    {
      "name": "change_bridge",
      "purpose": "Governed mutation flow",
      "commands": [
        "plan",
        "apply"
      ],
      "artifacts": [
        ".playbook/plan.json"
      ]
    },
    {
      "name": "routing_engine",
      "purpose": "Task classification and execution strategy",
      "commands": [
        "route"
      ],
      "artifacts": [
        ".playbook/execution-plan.json"
      ]
    },
    {
      "name": "orchestration_planner",
      "purpose": "Parallel work decomposition",
      "commands": [
        "orchestrate"
      ],
      "artifacts": [
        ".playbook/workset-plan.json"
      ]
    },
    {
      "name": "lane_lifecycle",
      "purpose": "Track orchestration progress",
      "commands": [
        "lanes"
      ],
      "artifacts": [
        ".playbook/lane-state.json"
      ]
    },
    {
      "name": "execution_supervisor",
      "purpose": "Run workers and monitor execution",
      "commands": [
        "execute",
        "cycle"
      ],
      "artifacts": [
        ".playbook/execution-state.json",
        ".playbook/cycle-state.json"
      ],
      "upstream": [
        "orchestration_planner"
      ],
      "downstream": [
        "telemetry_learning",
        "lane_lifecycle",
        "worker_coordination"
      ]
    },
    {
      "name": "worker_coordination",
      "purpose": "Worker assignment and prompt materialization",
      "commands": [
        "workers"
      ],
      "artifacts": [
        ".playbook/worker-assignments.json"
      ]
    },
    {
      "name": "telemetry_learning",
      "purpose": "Execution telemetry and learning state",
      "commands": [
        "telemetry"
      ],
      "artifacts": [
        ".playbook/learning-compaction.json",
        ".playbook/learning-state.json",
        ".playbook/outcome-telemetry.json",
        ".playbook/process-telemetry.json"
      ]
    },
    {
      "name": "repository_memory",
      "purpose": "Persistent execution history",
      "commands": [
        "memory"
      ],
      "artifacts": [
        ".playbook/memory/events/*",
        ".playbook/memory/index.json"
      ]
    },
    {
      "name": "improvement_engine",
      "purpose": "Detect recurring inefficiencies",
      "commands": [
        "improve"
      ],
      "artifacts": [
        ".playbook/improvement-candidates.json",
        ".playbook/router-improvement-proposals.json",
        ".playbook/router-recommendations.json"
      ]
    },
    {
      "name": "knowledge_lifecycle",
      "purpose": "Promote durable patterns",
      "commands": [
        "learn",
        "knowledge",
        "patterns"
      ],
      "artifacts": [],
      "upstream": [
        "telemetry_learning",
        "repository_memory",
        "observation_engine",
        "bootstrap_contract_surface"
      ],
      "downstream": [
        "improvement_engine"
      ]
    }
  ]
}
