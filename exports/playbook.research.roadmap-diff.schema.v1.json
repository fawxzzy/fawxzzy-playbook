{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fawxzzy.dev/schemas/playbook.research.roadmap-diff.v1.json",
  "title": "Playbook Research Roadmap Diff v1",
  "type": "object",
  "required": [
    "schemaVersion",
    "entries"
  ],
  "properties": {
    "schemaVersion": {
      "const": "playbook.research.roadmap-diff.v1"
    },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "featureId",
          "repo",
          "action",
          "title",
          "goal",
          "commands",
          "dependencies",
          "rationale",
          "reviewSource"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
          },
          "featureId": {
            "type": "string",
            "pattern": "^PB-V[0-9]+-[A-Z0-9-]+$"
          },
          "repo": {
            "enum": [
              "Playbook",
              "Fitness",
              "Lifeline"
            ]
          },
          "action": {
            "enum": [
              "promote_to_canonical",
              "sequence_after_dependency",
              "keep_review_only"
            ]
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "goal": {
            "type": "string",
            "minLength": 1
          },
          "commands": {
            "type": "array",
            "maxItems": 0,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "dependencies": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^PB-V[0-9]+-[A-Z0-9-]+$"
            }
          },
          "rationale": {
            "type": "string",
            "minLength": 1
          },
          "reviewSource": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
