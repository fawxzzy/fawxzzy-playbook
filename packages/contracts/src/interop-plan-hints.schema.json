{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://playbook.dev/schemas/interop-plan-hints.schema.json",
  "title": "Playbook Interop Plan Hints Artifact",
  "description": "Deterministic proposal-only next-plan hints compiled from interop followups and updated truth artifacts.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "kind",
    "command",
    "reviewOnly",
    "proposalOnly",
    "authority",
    "sourceArtifacts",
    "hints"
  ],
  "properties": {
    "schemaVersion": { "const": "1.0" },
    "kind": { "const": "interop-plan-hints-artifact" },
    "command": { "const": "interop plan-hints" },
    "reviewOnly": { "const": true },
    "proposalOnly": { "const": true },
    "authority": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mutation", "promotion"],
      "properties": {
        "mutation": { "const": "read-only" },
        "promotion": { "const": "review-required" }
      }
    },
    "sourceArtifacts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "followupsPath",
        "updatedTruthPath",
        "contractSourceHash",
        "contractSourceRef",
        "contractSourcePath"
      ],
      "properties": {
        "followupsPath": { "const": ".playbook/interop-followups.json" },
        "updatedTruthPath": { "const": ".playbook/interop-updated-truth.json" },
        "contractSourceHash": { "type": "string", "minLength": 1 },
        "contractSourceRef": { "type": "string", "minLength": 1 },
        "contractSourcePath": { "type": "string", "minLength": 1 }
      }
    },
    "hints": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "hintId",
          "requestId",
          "receiptId",
          "action",
          "receiptType",
          "canonicalOutcomeSummary",
          "recommendedPlanTarget",
          "reasonCode",
          "confidence",
          "provenanceRefs",
          "nextActionText"
        ],
        "properties": {
          "hintId": { "type": "string", "minLength": 1 },
          "requestId": { "type": "string", "minLength": 1 },
          "receiptId": { "type": "string", "minLength": 1 },
          "action": {
            "enum": [
              "adjust-plan-for-blocked-outcome",
              "add-bounded-retry-or-recovery-step",
              "promote-next-approved-planning-step"
            ]
          },
          "receiptType": { "type": "string", "minLength": 1 },
          "canonicalOutcomeSummary": {
            "type": "object",
            "additionalProperties": false,
            "required": ["outcome", "detail", "completedAt"],
            "properties": {
              "outcome": { "enum": ["completed", "blocked", "failed"] },
              "detail": { "type": "string", "minLength": 1 },
              "completedAt": { "type": "string", "format": "date-time" }
            }
          },
          "recommendedPlanTarget": { "type": "string", "minLength": 1 },
          "reasonCode": {
            "enum": [
              "repeated-blocked-runtime-outcome",
              "repeated-failed-runtime-outcome",
              "completed-bounded-state-advance"
            ]
          },
          "confidence": {
            "type": "object",
            "additionalProperties": false,
            "required": ["score", "rationale"],
            "properties": {
              "score": { "type": "number", "minimum": 0, "maximum": 1 },
              "rationale": { "type": "string", "minLength": 1 }
            }
          },
          "provenanceRefs": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "nextActionText": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
