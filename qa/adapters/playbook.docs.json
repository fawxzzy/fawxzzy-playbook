{
  "contract_version": "atlas.qa.adapter.v1",
  "adapter_id": "playbook.docs",
  "repo_id": "playbook",
  "repo_path": "repos/fawxzzy-playbook",
  "framework": "docs-or-runtime",
  "lens_manifest_ref": "ops/atlas/qa/lenses/atlas-default-web.v1.json",
  "commands": {
    "lint": {
      "command": "pnpm lint"
    },
    "verify": {
      "command": "pnpm verify"
    },
    "docs_verify": {
      "command": "pnpm docs:check"
    }
  },
  "lenses": [
    {
      "lens_id": "desktop.chromium.emulated",
      "profile_id": "desktop.chromium",
      "proof_kind": "emulated",
      "evidence_kind": "emulated_browser",
      "required_for": [
        "evidence",
        "promotion"
      ],
      "promotion_tier": "emulated_browser",
      "fallback_behavior": "blocked",
      "execution_mode": "repo_command",
      "command_ref": "docs_verify"
    }
  ],
  "supported_scenarios": [
    "playbook.docs-governance"
  ]
}
