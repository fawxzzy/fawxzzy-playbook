{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fawxzzy.dev/schemas/playbook.workflow-pack.environment-bridge.v1.json",
  "title": "Playbook Workflow Pack Environment Bridge v1",
  "type": "object",
  "required": [
    "schemaVersion",
    "workflowPackId",
    "environmentName",
    "verificationGate",
    "approvalPolicy",
    "requiredSecrets",
    "secretRefsOnly",
    "publishMode",
    "deploymentMode",
    "receiptRefs",
    "consumerRules"
  ],
  "properties": {
    "schemaVersion": {
      "const": "playbook.workflow-pack.environment-bridge.v1"
    },
    "workflowPackId": {
      "type": "string",
      "minLength": 1
    },
    "environmentName": {
      "type": "string",
      "minLength": 1
    },
    "verificationGate": {
      "type": "object",
      "required": [
        "mode",
        "requiredEvidenceRefs",
        "failurePolicy"
      ],
      "properties": {
        "mode": {
          "enum": [
            "local_verification_required",
            "local_and_promotion_required"
          ]
        },
        "requiredEvidenceRefs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "failurePolicy": {
          "enum": [
            "block"
          ]
        }
      },
      "additionalProperties": false
    },
    "approvalPolicy": {
      "type": "object",
      "required": [
        "mode",
        "requiredApprovals",
        "approverRoles"
      ],
      "properties": {
        "mode": {
          "enum": [
            "protected_environment",
            "manual_release_gate"
          ]
        },
        "requiredApprovals": {
          "type": "integer",
          "minimum": 1
        },
        "approverRoles": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "additionalProperties": false
    },
    "requiredSecrets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^ref://.+"
      }
    },
    "secretRefsOnly": {
      "const": true
    },
    "publishMode": {
      "enum": [
        "publish_after_verification",
        "promotion_only"
      ]
    },
    "deploymentMode": {
      "enum": [
        "receipt_only",
        "external_consumer_handoff"
      ]
    },
    "receiptRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "consumerRules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "additionalProperties": false
}
