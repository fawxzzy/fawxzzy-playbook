#!/bin/sh
set -eu

if [ -f "$(dirname "$0")/_/husky.sh" ]; then
  . "$(dirname "$0")/_/husky.sh"
fi

# Avoid unnecessary release sync runs on commits with no staged content.
if git diff --cached --quiet; then
  exit 0
fi

if pnpm playbook release sync --check >/dev/null 2>&1; then
  exit 0
fi

pnpm playbook release sync >/dev/null
git add docs/CHANGELOG.md ':(glob)packages/**/package.json'
echo "Release sync auto-applied and staged"
