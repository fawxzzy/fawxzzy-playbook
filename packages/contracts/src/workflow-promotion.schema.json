{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://playbook.dev/schemas/workflow-promotion.schema.json",
  "title": "Workflow Promotion Contract",
  "description": "Normalized staged-promotion metadata for durable workflow outputs that write repo-visible state.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "kind",
    "workflow_kind",
    "staged_generation",
    "candidate_artifact_path",
    "staged_artifact_path",
    "committed_target_path",
    "validation_status",
    "validation_passed",
    "promotion_status",
    "promoted",
    "committed_state_preserved",
    "blocked_reason",
    "error_summary",
    "generated_at",
    "summary"
  ],
  "properties": {
    "schemaVersion": { "type": "string", "const": "1.0" },
    "kind": { "type": "string", "const": "workflow-promotion" },
    "workflow_kind": { "type": "string", "minLength": 1 },
    "staged_generation": { "type": "boolean", "const": true },
    "candidate_artifact_path": { "type": "string", "minLength": 1 },
    "staged_artifact_path": { "type": "string", "minLength": 1 },
    "committed_target_path": { "type": "string", "minLength": 1 },
    "validation_status": { "type": "string", "enum": ["passed", "blocked"] },
    "validation_passed": { "type": "boolean" },
    "promotion_status": { "type": "string", "enum": ["promoted", "blocked"] },
    "promoted": { "type": "boolean" },
    "committed_state_preserved": { "type": "boolean" },
    "blocked_reason": { "type": ["string", "null"] },
    "error_summary": { "type": ["string", "null"] },
    "generated_at": { "type": "string", "format": "date-time" },
    "summary": { "type": "string", "minLength": 1 }
  }
}
