{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://playbook.dev/schemas/interop-request-draft.schema.json",
  "title": "Playbook Interop Request Draft Artifact",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "kind",
    "command",
    "draftId",
    "proposalId",
    "target",
    "capability",
    "action",
    "bounded_action_input",
    "expected_receipt_type",
    "routing_metadata",
    "blockers",
    "assumptions",
    "confidence",
    "provenance_refs",
    "nextActionText"
  ],
  "properties": {
    "schemaVersion": { "const": "1.0" },
    "kind": { "const": "interop-request-draft" },
    "command": { "const": "interop draft" },
    "draftId": { "type": "string" },
    "proposalId": { "type": "string" },
    "target": { "const": "fitness" },
    "capability": { "type": "string", "minLength": 1 },
    "action": {
      "enum": [
        "adjust_upcoming_workout_load",
        "schedule_recovery_block",
        "revise_weekly_goal_plan"
      ]
    },
    "bounded_action_input": { "type": "object" },
    "expected_receipt_type": {
      "enum": ["schedule_adjustment_applied", "recovery_guardrail_applied", "goal_plan_amended"]
    },
    "routing_metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["channel", "target", "priority", "maxDeliveryLatencySeconds", "constraints"],
      "properties": {
        "channel": { "type": "string" },
        "target": { "type": "string" },
        "priority": { "type": "string" },
        "maxDeliveryLatencySeconds": { "type": "number" },
        "constraints": { "type": "array", "items": { "type": "string" } }
      }
    },
    "blockers": { "type": "array", "items": { "type": "string" } },
    "assumptions": { "type": "array", "items": { "type": "string" } },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "provenance_refs": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "nextActionText": { "type": "string", "minLength": 1 }
  }
}
