{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://playbook.dev/schemas/promotion-receipt.schema.json",
  "title": "Playbook Promotion Receipt",
  "description": "Deterministic audited receipt emitted for each attempted story or pattern promotion or lifecycle mutation.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "kind",
    "receipt_id",
    "promotion_kind",
    "workflow_kind",
    "generated_at",
    "source_ref",
    "source_fingerprint",
    "target_artifact_path",
    "target_id",
    "before_fingerprint",
    "after_fingerprint",
    "outcome",
    "committed",
    "committed_state_preserved",
    "summary",
    "conflict_reason"
  ],
  "properties": {
    "schemaVersion": { "type": "string", "const": "1.0" },
    "kind": { "type": "string", "const": "promotion-receipt" },
    "receipt_id": { "type": "string", "minLength": 1 },
    "promotion_kind": { "type": "string", "enum": ["story", "pattern"] },
    "workflow_kind": {
      "type": "string",
      "enum": [
        "promote-story",
        "promote-pattern",
        "promote-pattern-retire",
        "promote-pattern-demote",
        "promote-pattern-recall",
        "promote-pattern-supersede"
      ]
    },
    "generated_at": { "type": "string", "format": "date-time" },
    "source_ref": { "type": "string", "minLength": 1 },
    "source_fingerprint": { "type": "string", "minLength": 1 },
    "target_artifact_path": { "type": "string", "minLength": 1 },
    "target_id": { "type": "string", "minLength": 1 },
    "before_fingerprint": { "type": ["string", "null"] },
    "after_fingerprint": { "type": ["string", "null"] },
    "outcome": { "type": "string", "enum": ["promoted", "noop", "conflict"] },
    "committed": { "type": "boolean" },
    "committed_state_preserved": { "type": "boolean" },
    "summary": { "type": "string", "minLength": 1 },
    "conflict_reason": { "type": ["string", "null"] }
  }
}
