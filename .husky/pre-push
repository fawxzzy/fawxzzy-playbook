#!/bin/sh
set -eu

if [ -f "$(dirname "$0")/_/husky.sh" ]; then
  . "$(dirname "$0")/_/husky.sh"
fi

echo "Checking release sync..."

if ! pnpm playbook release sync --check; then
  echo ""
  echo "Release drift detected."
  echo "Run: pnpm playbook release sync"
  echo "Then commit the changes before pushing."
  echo ""
  exit 1
fi

echo "Release sync valid."
