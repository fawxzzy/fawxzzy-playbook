#!/bin/sh
set -eu

if [ -f "$(dirname "$0")/_/husky.sh" ]; then
  . "$(dirname "$0")/_/husky.sh"
fi

# Avoid unnecessary release sync runs on commits with no staged content.
if git diff --cached --quiet; then
  exit 0
fi

if ! pnpm playbook release sync --check >/dev/null 2>&1; then
  echo "⚠️  Release drift detected during pre-commit (warning only)."
  echo "Use: pnpm playbook commit -m \"<message>\" to create an atomic release-clean commit."
fi
