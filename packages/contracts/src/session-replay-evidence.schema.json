{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://playbook.dev/schemas/session-replay-evidence.schema.json",
  "title": "PlaybookSessionReplayEvidence",
  "description": "Deterministic session and replay evidence envelope for temporal memory candidate generation. This evidence contract must not widen mutation authority or doctrine promotion.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "kind", "generatedAt", "memoryIndex", "replayInputs", "authority"],
  "properties": {
    "schemaVersion": { "const": "1.0" },
    "kind": { "const": "playbook-session-replay-evidence" },
    "generatedAt": { "type": "string", "format": "date-time" },
    "memoryIndex": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "eventCount"],
      "properties": {
        "path": { "const": ".playbook/memory/index.json" },
        "eventCount": { "type": "integer", "minimum": 0 }
      }
    },
    "replayInputs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["eventId", "sourcePath", "fingerprint", "scope"],
        "properties": {
          "eventId": { "type": "string", "minLength": 1 },
          "sourcePath": { "type": "string", "pattern": "^\\.playbook/memory/events/.+\\.json$" },
          "fingerprint": { "type": "string", "minLength": 1 },
          "runId": { "type": ["string", "null"] },
          "scope": {
            "type": "object",
            "additionalProperties": false,
            "required": ["modules", "ruleIds"],
            "properties": {
              "modules": { "type": "array", "items": { "type": "string", "minLength": 1 } },
              "ruleIds": { "type": "array", "items": { "type": "string", "minLength": 1 } }
            }
          }
        }
      }
    },
    "authority": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mutation", "promotion"],
      "properties": {
        "mutation": { "const": "read-only" },
        "promotion": { "const": "review-required" }
      }
    }
  }
}
