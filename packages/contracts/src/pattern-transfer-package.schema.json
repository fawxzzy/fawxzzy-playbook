{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://playbook.dev/schemas/pattern-transfer-package.schema.json",
  "title": "Pattern Transfer Package",
  "description": "Governed cross-repository package for reusable pattern transfer. Imports remain candidate-only pending local review.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "kind",
    "package_id",
    "exported_at",
    "pattern",
    "provenance",
    "sanitization",
    "compatibility",
    "governance_boundary",
    "risk_class",
    "known_failure_modes",
    "lifecycle_hooks"
  ],
  "properties": {
    "schemaVersion": { "type": "string", "const": "1.0" },
    "kind": { "type": "string", "const": "pattern-transfer-package" },
    "package_id": { "type": "string" },
    "exported_at": { "type": "string" },
    "pattern": { "type": "object" },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_pattern_id", "source_pattern_status", "source_candidate_id", "source_ref", "source_fingerprint", "source_artifact_path", "exported_by"],
      "properties": {
        "source_pattern_id": { "type": "string" },
        "source_pattern_status": { "type": "string", "enum": ["active", "superseded", "retired", "demoted"] },
        "source_candidate_id": { "type": "string" },
        "source_ref": { "type": "string" },
        "source_fingerprint": { "type": "string" },
        "source_artifact_path": { "type": "string" },
        "exported_by": { "type": "string", "const": "playbook" }
      }
    },
    "sanitization": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "reviewed_at", "notes"],
      "properties": {
        "status": { "type": "string", "enum": ["sanitized", "unsanitized", "needs-review"] },
        "reviewed_at": { "type": ["string", "null"] },
        "notes": { "type": "array", "items": { "type": "string" } }
      }
    },
    "compatibility": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "target_repo_id", "target_tags", "required_target_tags", "compatibility_notes", "failure_reason", "review_required", "fail_closed"],
      "properties": {
        "status": { "type": "string", "enum": ["compatible", "incompatible", "review-required"] },
        "target_repo_id": { "type": "string" },
        "target_tags": { "type": "array", "items": { "type": "string" } },
        "required_target_tags": { "type": "array", "items": { "type": "string" } },
        "compatibility_notes": { "type": "array", "items": { "type": "string" } },
        "failure_reason": { "type": ["string", "null"] },
        "review_required": { "type": "boolean" },
        "fail_closed": { "type": "boolean", "const": true }
      }
    },
    "governance_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["import_mode", "candidate_artifact_path", "local_truth_artifact_path", "execution_planning_effect", "review_required"],
      "properties": {
        "import_mode": { "type": "string", "const": "candidate-only" },
        "candidate_artifact_path": { "type": "string", "const": ".playbook/pattern-candidates.json" },
        "local_truth_artifact_path": { "type": "string", "const": ".playbook/patterns.json" },
        "execution_planning_effect": { "type": "string", "const": "none" },
        "review_required": { "type": "boolean", "const": true }
      }
    },
    "risk_class": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
    "known_failure_modes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "summary", "severity", "mitigation"],
        "properties": {
          "id": { "type": "string" },
          "summary": { "type": "string" },
          "severity": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
          "mitigation": { "type": ["string", "null"] }
        }
      }
    },
    "lifecycle_hooks": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_pattern_ref", "recall_supported", "demotion_supported", "source_status_at_export"],
      "properties": {
        "source_pattern_ref": { "type": "string" },
        "recall_supported": { "type": "boolean", "const": true },
        "demotion_supported": { "type": "boolean", "const": true },
        "source_status_at_export": { "type": "string", "enum": ["active", "superseded", "retired", "demoted"] }
      }
    }
  }
}
