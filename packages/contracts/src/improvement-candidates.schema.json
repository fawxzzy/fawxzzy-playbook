{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://playbook.dev/schemas/improvement-candidates.schema.json",
  "title": "PlaybookImprovementCandidates",
  "description": "Deterministic improvement candidate artifact derived from repository memory events and learning-state signals.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "kind",
    "generatedAt",
    "thresholds",
    "sourceArtifacts",
    "summary",
    "candidates",
    "opportunity_analysis"
  ],
  "properties": {
    "schemaVersion": {
      "const": "1.0"
    },
    "kind": {
      "const": "improvement-candidates"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "thresholds": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "minimum_recurrence",
        "minimum_confidence"
      ],
      "properties": {
        "minimum_recurrence": {
          "type": "integer",
          "minimum": 1,
          "const": 3
        },
        "minimum_confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "const": 0.6
        }
      }
    },
    "sourceArtifacts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "memoryEventsPath",
        "learningStatePath",
        "memoryEventCount",
        "learningStateAvailable"
      ],
      "properties": {
        "memoryEventsPath": {
          "type": "string",
          "minLength": 1
        },
        "learningStatePath": {
          "type": "string",
          "minLength": 1
        },
        "memoryEventCount": {
          "type": "integer",
          "minimum": 0
        },
        "learningStateAvailable": {
          "type": "boolean"
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "AUTO_SAFE",
        "CONVERSATIONAL",
        "GOVERNANCE",
        "total"
      ],
      "properties": {
        "AUTO_SAFE": {
          "type": "integer",
          "minimum": 0
        },
        "CONVERSATIONAL": {
          "type": "integer",
          "minimum": 0
        },
        "GOVERNANCE": {
          "type": "integer",
          "minimum": 0
        },
        "total": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "candidates": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/ImprovementCandidate"
      }
    },
    "opportunity_analysis": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "kind",
        "generatedAt",
        "proposalOnly",
        "reportOnly",
        "sourceArtifacts",
        "top_recommendation",
        "secondary_queue"
      ],
      "properties": {
        "schemaVersion": {
          "const": "1.0"
        },
        "kind": {
          "const": "opportunity-analysis"
        },
        "generatedAt": {
          "type": "string",
          "format": "date-time"
        },
        "proposalOnly": {
          "const": true
        },
        "reportOnly": {
          "const": true
        },
        "sourceArtifacts": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "scannedRoots",
            "filesScanned",
            "doctrineSources"
          ],
          "properties": {
            "scannedRoots": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "filesScanned": {
              "type": "integer",
              "minimum": 0
            },
            "doctrineSources": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "top_recommendation": {
          "anyOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/ImprovementOpportunity"
            }
          ]
        },
        "secondary_queue": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ImprovementOpportunity"
          }
        }
      }
    }
  },
  "$defs": {
    "ImprovementCandidate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "candidate_id",
        "category",
        "observation",
        "recurrence_count",
        "confidence_score",
        "suggested_action",
        "improvement_tier",
        "evidence"
      ],
      "properties": {
        "candidate_id": {
          "type": "string",
          "minLength": 1
        },
        "category": {
          "type": "string",
          "enum": [
            "routing",
            "orchestration",
            "worker_prompts",
            "validation_efficiency",
            "ontology",
            "remediation_learning"
          ]
        },
        "proposal_kind": {
          "type": "string",
          "enum": [
            "threshold_tuning",
            "repair_class_investigation",
            "verify_rule_improvement",
            "fixture_contract_hardening",
            "docs_doctrine_update"
          ]
        },
        "observation": {
          "type": "string",
          "minLength": 1
        },
        "recurrence_count": {
          "type": "integer",
          "minimum": 3
        },
        "confidence": {
          "type": "number",
          "minimum": 0.6,
          "maximum": 1
        },
        "suggested_action": {
          "type": "string",
          "minLength": 1
        },
        "improvement_tier": {
          "type": "string",
          "enum": [
            "auto_safe",
            "conversation",
            "governance"
          ]
        },
        "evidence": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "event_ids"
          ],
          "properties": {
            "event_ids": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              },
              "uniqueItems": true,
              "minItems": 1
            }
          }
        },
        "provenance": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "failure_signatures",
            "repair_classes",
            "outcomes",
            "latest_run_ids"
          ],
          "properties": {
            "remediation_source": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "remediationStatusPath",
                "remediationHistoryPath",
                "latestResultPath"
              ],
              "properties": {
                "remediationStatusPath": {
                  "type": "string",
                  "minLength": 1
                },
                "remediationHistoryPath": {
                  "type": "string",
                  "minLength": 1
                },
                "latestResultPath": {
                  "type": "string",
                  "minLength": 1
                }
              }
            },
            "failure_signatures": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              },
              "uniqueItems": true
            },
            "repair_classes": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              },
              "uniqueItems": true
            },
            "outcomes": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              },
              "uniqueItems": true
            },
            "latest_run_ids": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              },
              "uniqueItems": true
            }
          }
        },
        "confidence_score": {
          "type": "number",
          "minimum": 0.6,
          "maximum": 1
        }
      }
    },
    "ImprovementOpportunity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "opportunity_id",
        "title",
        "heuristic_class",
        "priority_score",
        "confidence",
        "why_it_matters",
        "likely_change_shape",
        "rationale",
        "evidence"
      ],
      "properties": {
        "opportunity_id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "heuristic_class": {
          "type": "string",
          "enum": [
            "duplicated_derivation_logic",
            "broad_query_fanout",
            "missing_invalidation_boundary",
            "repeated_recompute_loops",
            "canonical_id_inconsistency"
          ]
        },
        "priority_score": {
          "type": "number",
          "minimum": 0
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "why_it_matters": {
          "type": "string",
          "minLength": 1
        },
        "likely_change_shape": {
          "type": "string",
          "minLength": 1
        },
        "rationale": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "evidence": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/OpportunityEvidencePointer"
          }
        }
      }
    },
    "OpportunityEvidencePointer": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "file",
        "lines",
        "detail"
      ],
      "properties": {
        "file": {
          "type": "string",
          "minLength": 1
        },
        "lines": {
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 1
          }
        },
        "detail": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
