{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://playbook.dev/schemas/transfer-readiness.schema.json",
  "title": "Transfer Readiness Artifact",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "kind", "generatedAt", "readiness"],
  "properties": {
    "schemaVersion": { "type": "string", "const": "1.0" },
    "kind": { "type": "string", "const": "transfer-readiness" },
    "generatedAt": { "type": "string" },
    "readiness": {
      "type": "array",
      "items": { "$ref": "#/$defs/readinessEntry" }
    }
  },
  "$defs": {
    "readinessEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "pattern",
        "source_repo",
        "target_repo",
        "portability_confidence",
        "readiness_score",
        "touched_subsystems",
        "required_validations",
        "blockers",
        "open_questions"
      ],
      "properties": {
        "pattern": { "type": "string" },
        "source_repo": { "type": "string" },
        "target_repo": { "type": "string" },
        "portability_confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "readiness_score": { "type": "number", "minimum": 0, "maximum": 1 },
        "touched_subsystems": { "type": "array", "items": { "type": "string" } },
        "required_validations": { "type": "array", "items": { "type": "string" } },
        "blockers": { "type": "array", "items": { "type": "string" } },
        "open_questions": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
