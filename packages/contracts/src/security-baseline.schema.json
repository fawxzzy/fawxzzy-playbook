{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PlaybookSecurityBaseline",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "kind", "generatedAt", "findings"],
  "properties": {
    "schemaVersion": { "const": "1.0" },
    "kind": { "const": "security-baseline" },
    "generatedAt": { "type": "string" },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "package_name",
          "installed_version",
          "ecosystem",
          "vulnerability_id",
          "severity",
          "dependency_path",
          "direct_or_transitive",
          "status"
        ],
        "properties": {
          "package_name": { "type": "string" },
          "installed_version": { "type": "string" },
          "ecosystem": { "type": "string" },
          "vulnerability_id": { "type": "string" },
          "severity": { "type": "string" },
          "dependency_path": { "type": "string" },
          "direct_or_transitive": { "enum": ["direct", "transitive", "unknown"] },
          "status": { "enum": ["direct", "transitive", "tooling-only", "false-positive", "untriaged"] }
        }
      }
    }
  }
}
