{
  "schemaVersion": "1.0",
  "kind": "fitness-actions-and-receipts",
  "governance": {
    "loop": "signal->plan->action->receipt",
    "seam": "playbook-lifeline",
    "bypassAllowed": false
  },
  "actions": [
    {
      "action": "adjust_upcoming_workout_load",
      "receipt": "schedule_adjustment_applied",
      "routing": {
        "channel": "fitness.actions",
        "target": "training-load",
        "priority": "high",
        "maxDeliveryLatencySeconds": 300
      },
      "constraints": ["same_week_only", "max_duration_days_14"]
    },
    {
      "action": "schedule_recovery_block",
      "receipt": "recovery_guardrail_applied",
      "routing": {
        "channel": "fitness.actions",
        "target": "recovery",
        "priority": "high",
        "maxDeliveryLatencySeconds": 300
      },
      "constraints": ["same_week_only", "max_duration_days_14"]
    },
    {
      "action": "revise_weekly_goal_plan",
      "receipt": "goal_plan_amended",
      "routing": {
        "channel": "fitness.actions",
        "target": "weekly-plan",
        "priority": "high",
        "maxDeliveryLatencySeconds": 300
      },
      "constraints": ["same_week_only", "max_duration_days_14"]
    }
  ]
}
